# Copy to paths.env and edit only what differs on your machine:
#   cp paths.env.example paths.env
#
# One conda env (test_saspg / test_saspg_cu118) for ASR + SUPERB smoke.
# Bundled checkpoints ship in the repo (Git LFS) — see ASR/hf_models/ and SUPERB/pretrained/.

# Repo root (required: set to your clone path)
SASPG_REPO=/path/to/SASPG-pruning

# LibriSpeech audio on disk (NOT in git)
LIBRISPEECH_ROOT=/path/to/LibriSpeech

# --- Writable smoke work dir (gitignored) ---
WORK_ROOT="${SASPG_REPO}/validation_smoke_8exp/user_sim/work"

# --- Bundled models (defaults work after git lfs pull) ---
export HF_MODELS_SRC="${HF_MODELS_SRC:-${SASPG_REPO}/ASR/hf_models}"
export ASR_W2V_MODEL_PATH="${ASR_W2V_MODEL_PATH:-${HF_MODELS_SRC}/wav2vec2-base-100h}"
export ASR_HUBERT_MODEL_PATH="${ASR_HUBERT_MODEL_PATH:-${HF_MODELS_SRC}/hubert-large-librispeech-100h}"
export DPHuBERT_PRETRAINED_SRC="${DPHuBERT_PRETRAINED_SRC:-${SASPG_REPO}/SUPERB/pretrained}"

export SUPERB_HF_HUBERT_LARGE="${SUPERB_HF_HUBERT_LARGE:-${HF_MODELS_SRC}/hubert-large-ll60k}"
export SUPERB_HF_HUBERT_BASE="${SUPERB_HF_HUBERT_BASE:-${WORK_ROOT}/hf_models/hubert-base-ls960}"
export SUPERB_HF_W2V_SSL="${SUPERB_HF_W2V_SSL:-${HF_MODELS_SRC}/wav2vec2-base}"
export SUPERB_HF_WAVLM="${SUPERB_HF_WAVLM:-${HF_MODELS_SRC}/wavlm-base-plus}"

# --- Conda (shared ASR + SUPERB) ---
export CONDA_ENV_NAME_CU121="${CONDA_ENV_NAME_CU121:-test_saspg}"
export CONDA_ENV_NAME_CU118="${CONDA_ENV_NAME_CU118:-test_saspg_cu118}"
CONDA_ENV_NAME="${CONDA_ENV_NAME:-${CONDA_ENV_NAME_CU121}}"
export ASR_CUDA_VARIANT="${ASR_CUDA_VARIANT:-auto}"
export SUPERB_USE_ASR_CONDA="${SUPERB_USE_ASR_CONDA:-1}"
export SUPERB_CONDA_ENV="${SUPERB_CONDA_ENV:-}"

export ASR_SMOKE_OUT_ROOT="${ASR_SMOKE_OUT_ROOT:-${WORK_ROOT}/asr_smoke_out}"
export SMOKE_LOG_ROOT="${SMOKE_LOG_ROOT:-${WORK_ROOT}/logs}"
export SUPERB_SASPG_WORK_ROOT="${SUPERB_SASPG_WORK_ROOT:-${WORK_ROOT}/superb_saspg}"
export SUPERB_MAG_WORK_ROOT="${SUPERB_MAG_WORK_ROOT:-${WORK_ROOT}/superb_mag}"

# --- Smoke knobs ---
export MAX_STEPS="${MAX_STEPS:-50}"
export SMOKE_GPU_INDEX="${SMOKE_GPU_INDEX:-0}"
export WAIT_GPU_EACH_TASK="${WAIT_GPU_EACH_TASK:-1}"
export SUPERB_SMOKE_MAX="${SUPERB_SMOKE_MAX:-30}"
export SUPERB_SMOKE_FINAL_MAX="${SUPERB_SMOKE_FINAL_MAX:-15}"
export SUPERB_SMOKE_WARMUP="${SUPERB_SMOKE_WARMUP:-5}"
export SUPERB_SMOKE_SP_WARMUP="${SUPERB_SMOKE_SP_WARMUP:-5}"
export SMOKE_DEBUG_LOG="${SMOKE_DEBUG_LOG:-${WORK_ROOT}/orchestrator.log}"
