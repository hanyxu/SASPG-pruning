# Copy to env.sh and: source env.sh

# Repo root (optional; auto-detected from utils/librispeech_data.py)
# export SSLPRUNE_RELEASE_ROOT=/path/to/SSLprune_ASR_release

# LibriSpeech flac root (must contain dev-clean/, train-clean-100/, ...)
# Default: $SSLPRUNE_RELEASE_ROOT/data/librispeech/audio
export LIBRISPEECH_AUDIO_ROOT=

# CSV manifests (default: data/librispeech/csv_metadata in repo)
# export SSLPRUNE_LIBRISPEECH_CSV_ROOT=

# Preprocessed dataset Arrow cache (default: cache/processed_audio)
# export SSLPRUNE_DATASET_CACHE=

# HuggingFace hub download cache (default: cache/hf)
# export HF_HOME=

# Optional: save filtered train split after first run
# export SAVE_FILTERED_TRAIN_CACHE=1

# Test decode transcripts (default: <output-dir>/decode)
# export SSLPRUNE_DECODE_DIR=
